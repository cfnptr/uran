#pragma once

#define __URAN__

#define URAN_VERSION_MAJOR @uran_VERSION_MAJOR@
#define URAN_VERSION_MINOR @mpgx_VERSION_MINOR@
#define URAN_VERSION_PATCH @mpgx_VERSION_PATCH@

/*
 * Uran results.
 */
typedef enum UranResult_T
{
	SUCCESS_URAN_RESULT = 0,
	URAN_RESULT_COUNT = 23,
} UranResult_T;
/*
 * Uran result type.
 */
typedef uint8_t UranResult;

/*
 * Uran result strings.
 */
static const char* const uranResultStrings[URAN_RESULT_COUNT] = {
	"Success",
};

/*
 * Returns Uran result as string.
 * result - Uran result.
 */
inline static const char* uranResultToString(
	UranResult result)
{
	if (result >= URAN_RESULT_COUNT)
		return "Unknown Uran result";
	return uranResultStrings[result];
}
