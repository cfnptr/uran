#pragma once
#include <stdint.h>

#define __URAN__

#define URAN_VERSION_MAJOR @uran_VERSION_MAJOR@
#define URAN_VERSION_MINOR @uran_VERSION_MINOR@
#define URAN_VERSION_PATCH @uran_VERSION_PATCH@

#define URAN_VERSION_STRING \
	"@uran_VERSION_MAJOR@." \
	"@uran_VERSION_MINOR@." \
	"@uran_VERSION_PATCH@"

/*
 * Uran results.
 */
typedef enum UranResult_T
{
	SUCCESS_URAN_RESULT = 0,
	FAILED_TO_ALLOCATE_URAN_RESULT = 1,
	FAILED_TO_OPEN_FILE_URAN_RESULT = 2,
	FAILED_TO_SEEK_FILE_URAN_RESULT = 3,
	FAILED_TO_READ_FILE_URAN_RESULT = 4,
	BAD_DATA_URAN_RESULT = 5,
	FORMAT_IS_NOT_SUPPORTED_URAN_RESULT = 6,
	URAN_RESULT_COUNT = 7,
} UranResult_T;
/*
 * Uran result type.
 */
typedef uint8_t UranResult;

/*
 * Uran result strings.
 */
static const char* const uranResultStrings[URAN_RESULT_COUNT] = {
	"Success",
	"Failed to allocate",
	"Failed to open file",
	"Failed to seek file",
	"Failed to read file",
	"Bad data",
	"Format is not supported",
};

/*
 * Returns Uran result as string.
 * result - Uran result.
 */
inline static const char* uranResultToString(
	UranResult result)
{
	if (result >= URAN_RESULT_COUNT)
		return "Unknown Uran result";
	return uranResultStrings[result];
}
